class Solution(object):
    def rotateString(self, s, goal):
        """
        :type s: str
        :type goal: str
        :rtype: bool
        """
        if len(s) != len(goal):
            return False
        
        strs = s + s

        is_rotation = False

        if goal in strs:
            is_rotation = True

        return is_rotation

        
